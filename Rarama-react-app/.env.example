# Documentation-only example. Copy this file to .env and fill in real values.
# Never commit .env to git.
# All frontend environment variables must start with REACT_APP_.

# Backend API base URL (use https:// in production)
REACT_APP_API_URL=http://127.0.0.1:8000/api

# OpenWeather API base URL
REACT_APP_WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# OpenWeather API key — get a free key at https://openweathermap.org/api
REACT_APP_WEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE
